package service

import (
	"errors"
	"strings"
	"testing"

	"github.com/apsferreira/auth-service/backend/internal/domain"
	"github.com/apsferreira/auth-service/backend/internal/repository/mocks"
	"github.com/google/uuid"
)

func createTestAdminService() (*AdminService, *mocks.MockServiceRepository, *mocks.MockPermissionRepository, *mocks.MockRoleRepository) {
	mockServiceRepo := &mocks.MockServiceRepository{}
	mockPermissionRepo := &mocks.MockPermissionRepository{}
	mockRoleRepo := &mocks.MockRoleRepository{}

	adminSvc := NewAdminService(mockServiceRepo, mockPermissionRepo, mockRoleRepo)
	return adminSvc, mockServiceRepo, mockPermissionRepo, mockRoleRepo
}

// ─── CreateService ───────────────────────────────────────────────────────────

func TestAdminService_CreateService_Success(t *testing.T) {
	adminSvc, mockServiceRepo, _, _ := createTestAdminService()

	tenantID := uuid.New()
	req := domain.ServiceCreateRequest{
		Name:        "Test Service",
		Slug:        "test-service",
		Description: "A test service",
	}

	mockServiceRepo.CreateFn = func(service *domain.Service) error {
		if service.Name != req.Name {
			t.Errorf("expected name %s, got %s", req.Name, service.Name)
		}
		return nil
	}

	service, err := adminSvc.CreateService(tenantID, req)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if service == nil {
		t.Fatal("expected service, got nil")
	}
}

func TestAdminService_CreateService_EmptyName(t *testing.T) {
	adminSvc, _, _, _ := createTestAdminService()

	req := domain.ServiceCreateRequest{
		Name: "",
		Slug: "test",
	}

	_, err := adminSvc.CreateService(uuid.New(), req)

	if err == nil {
		t.Fatal("expected error for empty name, got nil")
	}
	if !strings.Contains(err.Error(), "name and slug are required") {
		t.Errorf("expected 'name and slug are required' error, got: %v", err)
	}
}

func TestAdminService_CreateService_CreateError(t *testing.T) {
	adminSvc, mockServiceRepo, _, _ := createTestAdminService()

	req := domain.ServiceCreateRequest{
		Name: "Test",
		Slug: "test",
	}

	mockServiceRepo.CreateFn = func(service *domain.Service) error {
		return errors.New("create failed")
	}

	_, err := adminSvc.CreateService(uuid.New(), req)

	if err == nil {
		t.Fatal("expected error, got nil")
	}
	if !strings.Contains(err.Error(), "failed to create service") {
		t.Errorf("expected 'failed to create service' error, got: %v", err)
	}
}

// ─── GetService / ListServices / UpdateService / DeleteService ──────────────

func TestAdminService_GetService_Success(t *testing.T) {
	adminSvc, mockServiceRepo, _, _ := createTestAdminService()

	serviceID := uuid.New()
	expectedService := &domain.Service{
		ID:   serviceID,
		Name: "Test Service",
	}

	mockServiceRepo.FindByIDFn = func(id uuid.UUID) (*domain.Service, error) {
		return expectedService, nil
	}

	service, err := adminSvc.GetService(serviceID)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if service.ID != serviceID {
		t.Error("expected service with correct ID")
	}
}

func TestAdminService_ListServices_Success(t *testing.T) {
	adminSvc, mockServiceRepo, _, _ := createTestAdminService()

	tenantID := uuid.New()
	expectedServices := []*domain.Service{
		{ID: uuid.New(), Name: "Service 1"},
		{ID: uuid.New(), Name: "Service 2"},
	}

	mockServiceRepo.ListFn = func(tid uuid.UUID) ([]*domain.Service, error) {
		return expectedServices, nil
	}

	services, err := adminSvc.ListServices(tenantID)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if len(services) != 2 {
		t.Errorf("expected 2 services, got %d", len(services))
	}
}

func TestAdminService_UpdateService_Success(t *testing.T) {
	adminSvc, mockServiceRepo, _, _ := createTestAdminService()

	serviceID := uuid.New()
	req := domain.ServiceUpdateRequest{}

	mockServiceRepo.UpdateFn = func(id uuid.UUID, r domain.ServiceUpdateRequest) (*domain.Service, error) {
		return &domain.Service{ID: id}, nil
	}

	service, err := adminSvc.UpdateService(serviceID, req)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if service.ID != serviceID {
		t.Error("expected service with correct ID")
	}
}

func TestAdminService_DeleteService_Success(t *testing.T) {
	adminSvc, mockServiceRepo, _, _ := createTestAdminService()

