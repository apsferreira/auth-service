// ─── GetRolePermissions / SetRolePermissions ─────────────────────────────────

func TestAdminService_GetRolePermissions_Success(t *testing.T) {
	adminSvc, _, mockPermissionRepo, _ := createTestAdminService()

	roleID := uuid.New()
	expectedIDs := []uuid.UUID{uuid.New(), uuid.New()}

	mockPermissionRepo.GetRolePermissionIDsFn = func(rid uuid.UUID) ([]uuid.UUID, error) {
		return expectedIDs, nil
	}

	ids, err := adminSvc.GetRolePermissions(roleID)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if len(ids) != 2 {
		t.Errorf("expected 2 permission IDs, got %d", len(ids))
	}
}

func TestAdminService_SetRolePermissions_Success(t *testing.T) {
	adminSvc, _, mockPermissionRepo, _ := createTestAdminService()

	roleID := uuid.New()
	permissionIDs := []uuid.UUID{uuid.New(), uuid.New()}

	mockPermissionRepo.SetRolePermissionsFn = func(rid uuid.UUID, pids []uuid.UUID) error {
		if len(pids) != 2 {
			t.Errorf("expected 2 permission IDs, got %d", len(pids))
		}
		return nil
	}

	err := adminSvc.SetRolePermissions(roleID, permissionIDs)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
}
