// ─── CreatePermission ────────────────────────────────────────────────────────

func TestAdminService_CreatePermission_Success(t *testing.T) {
	adminSvc, mockServiceRepo, mockPermissionRepo, _ := createTestAdminService()

	serviceID := uuid.New()
	req := domain.PermissionCreateRequest{
		Name:     "Read Users",
		Resource: "users",
		Action:   "read",
	}

	mockServiceRepo.FindByIDFn = func(id uuid.UUID) (*domain.Service, error) {
		return &domain.Service{ID: id}, nil
	}
	mockPermissionRepo.CreateFn = func(perm *domain.Permission) error {
		return nil
	}

	perm, err := adminSvc.CreatePermission(serviceID, req)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if perm == nil {
		t.Fatal("expected permission, got nil")
	}
}

func TestAdminService_CreatePermission_EmptyFields(t *testing.T) {
	adminSvc, _, _, _ := createTestAdminService()

	req := domain.PermissionCreateRequest{
		Name:     "",
		Resource: "users",
