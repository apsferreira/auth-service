func TestAdminService_CreatePermission_ServiceNotFound(t *testing.T) {
	adminSvc, mockServiceRepo, _, _ := createTestAdminService()

	req := domain.PermissionCreateRequest{
		Name:     "Read Users",
		Resource: "users",
		Action:   "read",
	}

	mockServiceRepo.FindByIDFn = func(id uuid.UUID) (*domain.Service, error) {
		return nil, errors.New("not found")
	}

	_, err := adminSvc.CreatePermission(uuid.New(), req)

	if err == nil {
		t.Fatal("expected error, got nil")
	}
	if !strings.Contains(err.Error(), "service not found") {
		t.Errorf("expected 'service not found' error, got: %v", err)
	}
}

