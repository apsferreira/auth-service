package service

import (
	"database/sql"
	"errors"
	"testing"

	"github.com/apsferreira/auth-service/backend/internal/domain"
	"github.com/apsferreira/auth-service/backend/internal/repository/mocks"
	"github.com/google/uuid"
)

// ─── List ────────────────────────────────────────────────────────────────────

func TestUserService_List_Success(t *testing.T) {
	tenantID := uuid.New()
	expectedUsers := []*domain.User{
		{ID: uuid.New(), Email: "test1@example.com"},
		{ID: uuid.New(), Email: "test2@example.com"},
	}

	mockRepo := &mocks.MockUserRepository{
		ListFn: func(tid uuid.UUID) ([]*domain.User, error) {
			if tid != tenantID {
				t.Errorf("expected tenantID %v, got %v", tenantID, tid)
			}
			return expectedUsers, nil
		},
	}

	svc := NewUserService(mockRepo)
	users, err := svc.List(tenantID)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if len(users) != 2 {
		t.Errorf("expected 2 users, got %d", len(users))
	}
}

func TestUserService_List_Error(t *testing.T) {
	tenantID := uuid.New()
	mockRepo := &mocks.MockUserRepository{
		ListFn: func(tid uuid.UUID) ([]*domain.User, error) {
			return nil, errors.New("database error")
		},
	}

	svc := NewUserService(mockRepo)
	users, err := svc.List(tenantID)

	if err == nil {
		t.Fatal("expected error, got nil")
	}
	if users != nil {
		t.Errorf("expected nil users, got %v", users)
	}
}

// ─── GetByID ─────────────────────────────────────────────────────────────────

func TestUserService_GetByID_Success(t *testing.T) {
	userID := uuid.New()
	expectedUser := &domain.User{ID: userID, Email: "test@example.com"}

	mockRepo := &mocks.MockUserRepository{
		FindByIDFn: func(id uuid.UUID) (*domain.User, error) {
			if id != userID {
				t.Errorf("expected userID %v, got %v", userID, id)
			}
			return expectedUser, nil
		},
	}

	svc := NewUserService(mockRepo)
	user, err := svc.GetByID(userID)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if user.ID != userID {
		t.Errorf("expected user ID %v, got %v", userID, user.ID)
	}
}

func TestUserService_GetByID_NotFound(t *testing.T) {
	userID := uuid.New()
	mockRepo := &mocks.MockUserRepository{
		FindByIDFn: func(id uuid.UUID) (*domain.User, error) {
			return nil, sql.ErrNoRows
		},
	}

	svc := NewUserService(mockRepo)
	user, err := svc.GetByID(userID)

	if err != sql.ErrNoRows {
		t.Fatalf("expected sql.ErrNoRows, got %v", err)
	}
	if user != nil {
		t.Errorf("expected nil user, got %v", user)
	}
}

