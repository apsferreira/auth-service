// ─── Update ──────────────────────────────────────────────────────────────────

func TestUserService_Update_Success(t *testing.T) {
	userID := uuid.New()
	name := "Updated Name"
	req := domain.UserUpdateRequest{
		FullName: &name,
	}

	updatedUser := &domain.User{
		ID:       userID,
		Email:    "test@example.com",
		FullName: "Updated Name",
	}

	mockRepo := &mocks.MockUserRepository{
		UpdateFn: func(id uuid.UUID, r domain.UserUpdateRequest) (*domain.User, error) {
			if id != userID {
				t.Errorf("expected userID %v, got %v", userID, id)
			}
			return updatedUser, nil
		},
	}

	svc := NewUserService(mockRepo)
	user, err := svc.Update(userID, req)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if user.FullName != "Updated Name" {
		t.Errorf("expected FullName 'Updated Name', got %s", user.FullName)
	}
}

func TestUserService_Update_Error(t *testing.T) {
	userID := uuid.New()
	name := "Updated Name"
	req := domain.UserUpdateRequest{
		FullName: &name,
	}

	mockRepo := &mocks.MockUserRepository{
		UpdateFn: func(id uuid.UUID, r domain.UserUpdateRequest) (*domain.User, error) {
			return nil, errors.New("update failed")
		},
	}

	svc := NewUserService(mockRepo)
	user, err := svc.Update(userID, req)

	if err == nil {
		t.Fatal("expected error, got nil")
	}
	if user != nil {
		t.Errorf("expected nil user, got %v", user)
	}
}

