func TestUserService_Create_UserAlreadyExists(t *testing.T) {
	tenantID := uuid.New()
	existingUser := &domain.User{ID: uuid.New(), Email: "test@example.com"}

	mockRepo := &mocks.MockUserRepository{
		FindByEmailFn: func(email string) (*domain.User, error) {
			return existingUser, nil
		},
	}

	svc := NewUserService(mockRepo)
	req := domain.UserCreateRequest{
		Email:    "test@example.com",
		TenantID: tenantID.String(),
		FullName: "Test User",
	}

	user, err := svc.Create(req)
	if err == nil || err.Error() != "user with this email already exists" {
		t.Fatalf("expected 'user already exists' error, got %v", err)
	}
	if user != nil {
		t.Errorf("expected nil user, got %v", user)
	}
}

func TestUserService_Create_Success(t *testing.T) {
	tenantID := uuid.New()
	roleID := uuid.New()
	roleIDStr := roleID.String()

	createdUser := &domain.User{
		ID:       uuid.New(),
		TenantID: tenantID,
		Email:    "test@example.com",
		FullName: "Test User",
		RoleID:   &roleID,
		IsActive: true,
	}

	mockRepo := &mocks.MockUserRepository{
		FindByEmailFn: func(email string) (*domain.User, error) {
			return nil, sql.ErrNoRows
		},
		CreateFn: func(user *domain.User) error {
			if user.Email != "test@example.com" {
				t.Errorf("expected email test@example.com, got %s", user.Email)
			}
			if user.TenantID != tenantID {
				t.Errorf("expected tenantID %v, got %v", tenantID, user.TenantID)
			}
			return nil
		},
		AddUserRoleFn: func(userID, roleID uuid.UUID) error {
			return nil
		},
		FindByIDFn: func(id uuid.UUID) (*domain.User, error) {
			return createdUser, nil
		},
	}

	svc := NewUserService(mockRepo)
	req := domain.UserCreateRequest{
		Email:    "test@example.com",
		TenantID: tenantID.String(),
		FullName: "Test User",
		RoleID:   &roleIDStr,
	}

	user, err := svc.Create(req)
	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if user == nil {
		t.Fatal("expected user, got nil")
	}
	if user.Email != "test@example.com" {
		t.Errorf("expected email test@example.com, got %s", user.Email)
	}
}

