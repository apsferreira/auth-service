func TestOTPService_GenerateAndStore_ExpiryTime(t *testing.T) {
	var createdOTP *domain.OTPCode
	expiryMinutes := 10

	mockRepo := &mocks.MockOTPRepository{
		CountRecentByEmailFn: func(email string, since time.Time) (int, error) {
			return 0, nil
		},
		CreateFn: func(otp *domain.OTPCode) error {
			createdOTP = otp
			return nil
		},
	}

	svc := NewOTPService(mockRepo, expiryMinutes, 3, 5, 15)
	_, err := svc.GenerateAndStore("test@example.com")

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}

	expectedExpiry := time.Now().Add(time.Duration(expiryMinutes) * time.Minute)
	if createdOTP.ExpiresAt.Before(expectedExpiry.Add(-1*time.Second)) || createdOTP.ExpiresAt.After(expectedExpiry.Add(1*time.Second)) {
		t.Errorf("expected expiry around %v, got %v", expectedExpiry, createdOTP.ExpiresAt)
	}
}

// ─── Verify ──────────────────────────────────────────────────────────────────

func TestOTPService_Verify_NoOTPFound(t *testing.T) {
	mockRepo := &mocks.MockOTPRepository{
		FindLatestByEmailFn: func(email string) (*domain.OTPCode, error) {
			return nil, errors.New("not found")
		},
	}

	svc := NewOTPService(mockRepo, 10, 3, 5, 15)
	err := svc.Verify("test@example.com", "123456")

	if err == nil {
		t.Fatal("expected error, got nil")
	}
	if !strings.Contains(err.Error(), "no valid OTP found") {
		t.Errorf("expected 'no valid OTP found' error, got: %v", err)
	}
}

func TestOTPService_Verify_MaxAttemptsExceeded(t *testing.T) {
	hash, _ := bcrypt.GenerateFromPassword([]byte("123456"), bcrypt.DefaultCost)
	otp := &domain.OTPCode{
		ID:        uuid.New(),
		Email:     "test@example.com",
		CodeHash:  string(hash),
		Attempts:  3, // já atingiu maxAttempts
		ExpiresAt: time.Now().Add(10 * time.Minute),
	}

	mockRepo := &mocks.MockOTPRepository{
		FindLatestByEmailFn: func(email string) (*domain.OTPCode, error) {
			return otp, nil
		},
	}

	svc := NewOTPService(mockRepo, 10, 3, 5, 15)
	err := svc.Verify("test@example.com", "123456")

	if err == nil {
		t.Fatal("expected error, got nil")
	}
	if !strings.Contains(err.Error(), "maximum verification attempts exceeded") {
		t.Errorf("expected max attempts error, got: %v", err)
	}
}

func TestOTPService_Verify_Expired(t *testing.T) {
	hash, _ := bcrypt.GenerateFromPassword([]byte("123456"), bcrypt.DefaultCost)
	otp := &domain.OTPCode{
		ID:        uuid.New(),
		Email:     "test@example.com",
		CodeHash:  string(hash),
		Attempts:  0,
		ExpiresAt: time.Now().Add(-1 * time.Minute), // expirado
	}

	mockRepo := &mocks.MockOTPRepository{
		FindLatestByEmailFn: func(email string) (*domain.OTPCode, error) {
			return otp, nil
		},
		IncrementAttemptsFn: func(id uuid.UUID) error {
			return nil
		},
	}

	svc := NewOTPService(mockRepo, 10, 3, 5, 15)
	err := svc.Verify("test@example.com", "123456")

	if err == nil {
		t.Fatal("expected error, got nil")
	}
	if !strings.Contains(err.Error(), "OTP has expired") {
		t.Errorf("expected expired error, got: %v", err)
	}
}

func TestOTPService_Verify_InvalidCode(t *testing.T) {
	hash, _ := bcrypt.GenerateFromPassword([]byte("123456"), bcrypt.DefaultCost)
	otp := &domain.OTPCode{
		ID:        uuid.New(),
		Email:     "test@example.com",
		CodeHash:  string(hash),
		Attempts:  0,
		ExpiresAt: time.Now().Add(10 * time.Minute),
	}

	mockRepo := &mocks.MockOTPRepository{
		FindLatestByEmailFn: func(email string) (*domain.OTPCode, error) {
			return otp, nil
		},
		IncrementAttemptsFn: func(id uuid.UUID) error {
			return nil
		},
	}

	svc := NewOTPService(mockRepo, 10, 3, 5, 15)
	err := svc.Verify("test@example.com", "999999") // código errado

	if err == nil {
		t.Fatal("expected error, got nil")
	}
	if !strings.Contains(err.Error(), "invalid OTP code") {
		t.Errorf("expected invalid code error, got: %v", err)
