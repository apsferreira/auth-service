	}
}

// ─── GetExpiryMinutes ────────────────────────────────────────────────────────

func TestOTPService_GetExpiryMinutes(t *testing.T) {
	mockRepo := &mocks.MockOTPRepository{}
	svc := NewOTPService(mockRepo, 15, 3, 5, 15)

	if svc.GetExpiryMinutes() != 15 {
		t.Errorf("expected 15, got %d", svc.GetExpiryMinutes())
	}
}
