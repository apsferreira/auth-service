// ─── GenerateAndStore ────────────────────────────────────────────────────────

func TestOTPService_GenerateAndStore_RateLimitExceeded(t *testing.T) {
	mockRepo := &mocks.MockOTPRepository{
		CountRecentByEmailFn: func(email string, since time.Time) (int, error) {
			return 5, nil // já atingiu o limite
		},
	}

	svc := NewOTPService(mockRepo, 10, 3, 5, 15)
	_, err := svc.GenerateAndStore("test@example.com")

	if err == nil {
		t.Fatal("expected rate limit error, got nil")
	}
	if !strings.Contains(err.Error(), "rate limit exceeded") {
		t.Errorf("expected rate limit error, got: %v", err)
	}
}

func TestOTPService_GenerateAndStore_CountError(t *testing.T) {
	mockRepo := &mocks.MockOTPRepository{
		CountRecentByEmailFn: func(email string, since time.Time) (int, error) {
			return 0, errors.New("database error")
