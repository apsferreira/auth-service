func TestOTPService_Verify_Success(t *testing.T) {
	hash, _ := bcrypt.GenerateFromPassword([]byte("123456"), bcrypt.DefaultCost)
	otp := &domain.OTPCode{
		ID:        uuid.New(),
		Email:     "test@example.com",
		CodeHash:  string(hash),
		Attempts:  0,
		ExpiresAt: time.Now().Add(10 * time.Minute),
	}

	incrementCalled := false
	deleteCalled := false

	mockRepo := &mocks.MockOTPRepository{
		FindLatestByEmailFn: func(email string) (*domain.OTPCode, error) {
			return otp, nil
		},
		IncrementAttemptsFn: func(id uuid.UUID) error {
			incrementCalled = true
			return nil
		},
		DeleteByEmailFn: func(email string) error {
			deleteCalled = true
			return nil
		},
	}

	svc := NewOTPService(mockRepo, 10, 3, 5, 15)
	err := svc.Verify("test@example.com", "123456")

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if !incrementCalled {
		t.Error("expected IncrementAttempts to be called")
	}
	if !deleteCalled {
		t.Error("expected DeleteByEmail to be called")
	}
}

func TestOTPService_Verify_IncrementAttemptsIgnored(t *testing.T) {
	// IncrementAttempts pode falhar, mas não deve bloquear a verificação
	hash, _ := bcrypt.GenerateFromPassword([]byte("123456"), bcrypt.DefaultCost)
	otp := &domain.OTPCode{
		ID:        uuid.New(),
		Email:     "test@example.com",
		CodeHash:  string(hash),
		Attempts:  0,
		ExpiresAt: time.Now().Add(10 * time.Minute),
	}

	mockRepo := &mocks.MockOTPRepository{
		FindLatestByEmailFn: func(email string) (*domain.OTPCode, error) {
			return otp, nil
		},
		IncrementAttemptsFn: func(id uuid.UUID) error {
			return errors.New("increment failed") // erro ignorado
		},
		DeleteByEmailFn: func(email string) error {
			return nil
		},
	}

	svc := NewOTPService(mockRepo, 10, 3, 5, 15)
	err := svc.Verify("test@example.com", "123456")

	// Verification should still succeed even if IncrementAttempts fails (it's ignored)
	if err != nil {
		t.Fatalf("expected no error (increment failure ignored), got %v", err)
	}
}

func TestOTPService_Verify_DeleteByEmailIgnored(t *testing.T) {
	// DeleteByEmail pode falhar, mas não deve bloquear a verificação
	hash, _ := bcrypt.GenerateFromPassword([]byte("123456"), bcrypt.DefaultCost)
	otp := &domain.OTPCode{
