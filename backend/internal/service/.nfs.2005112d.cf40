// ─── RefreshTokens ───────────────────────────────────────────────────────────

func TestAuthService_RefreshTokens_Success(t *testing.T) {
	authSvc, mockUserRepo, mockTokenRepo, _, _ := createTestAuthService()

	userID := uuid.New()
	tenantID := uuid.New()
	tokenValue := "test-refresh-token"
	tokenHash := jwtpkg.HashToken(tokenValue)

	mockTokenRepo.FindByHashFn = func(hash string) (*domain.RefreshToken, error) {
		return &domain.RefreshToken{
			ID:        uuid.New(),
			UserID:    userID,
			TokenHash: tokenHash,
			ExpiresAt: time.Now().Add(7 * 24 * time.Hour),
		}, nil
	}
	mockTokenRepo.RevokeFn = func(id uuid.UUID) error {
		return nil
	}
	mockTokenRepo.CreateFn = func(token *domain.RefreshToken) error {
		return nil
	}
	mockUserRepo.FindByIDFn = func(id uuid.UUID) (*domain.User, error) {
		return &domain.User{
			ID:       userID,
			TenantID: tenantID,
			Email:    "test@example.com",
		}, nil
	}
	mockUserRepo.GetUserRolesAndPermissionsFn = func(uid uuid.UUID) ([]string, map[string][]string, error) {
		return []string{"user"}, map[string][]string{}, nil
	}

	resp, err := authSvc.RefreshTokens(tokenValue)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if resp == nil {
		t.Fatal("expected response, got nil")
	}
	if resp.AccessToken == "" {
		t.Error("expected new access token")
	}
	if resp.RefreshToken == "" {
		t.Error("expected new refresh token")
	}
}

