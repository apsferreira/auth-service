package service

import (
	"database/sql"
	"errors"
	"strings"
	"testing"
	"time"

	"github.com/apsferreira/auth-service/backend/internal/domain"
	jwtpkg "github.com/apsferreira/auth-service/backend/internal/pkg/jwt"
	"github.com/apsferreira/auth-service/backend/internal/repository/mocks"
	"github.com/google/uuid"
	"golang.org/x/crypto/bcrypt"
)

func createTestAuthService() (*AuthService, *mocks.MockUserRepository, *mocks.MockTokenRepository, *OTPService, *mocks.MockOTPRepository) {
	mockUserRepo := &mocks.MockUserRepository{}
	mockTokenRepo := &mocks.MockTokenRepository{}
	mockOTPRepo := &mocks.MockOTPRepository{}

	otpSvc := NewOTPService(mockOTPRepo, 10, 3, 5, 15)
	jwtSvc := jwtpkg.NewJWTService("test-secret", 15*time.Minute, 7*24*time.Hour)
	emailSvc := NewEmailService("", "test@example.com", "development")

	authSvc := NewAuthService(
		mockUserRepo,
		otpSvc,
		emailSvc,
		nil, // telegramNotifier
		nil, // whatsappService
		mockTokenRepo,
		jwtSvc,
	)

	return authSvc, mockUserRepo, mockTokenRepo, otpSvc, mockOTPRepo
}

// ─── RequestOTP ──────────────────────────────────────────────────────────────

func TestAuthService_RequestOTP_UserNotFound_CreateDefault(t *testing.T) {
	authSvc, mockUserRepo, _, _, mockOTPRepo := createTestAuthService()

	tenantID := uuid.New()
	roleID := uuid.New()

	mockUserRepo.FindByEmailFn = func(email string) (*domain.User, error) {
		return nil, sql.ErrNoRows
	}
	mockUserRepo.GetDefaultTenantIDFn = func() (uuid.UUID, error) {
		return tenantID, nil
	}
	mockUserRepo.GetDefaultRoleIDFn = func(tid uuid.UUID) (uuid.UUID, error) {
		return roleID, nil
	}
	mockUserRepo.CreateFn = func(user *domain.User) error {
		return nil
	}
	mockUserRepo.AddUserRoleFn = func(userID, roleID uuid.UUID) error {
		return nil
	}
	mockOTPRepo.CountRecentByEmailFn = func(email string, since time.Time) (int, error) {
		return 0, nil
	}
	mockOTPRepo.CreateFn = func(otp *domain.OTPCode) error {
		return nil
	}

	resp, code, err := authSvc.RequestOTP("test@example.com", "email")

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if resp == nil {
		t.Fatal("expected response, got nil")
	}
	if len(code) != 6 {
		t.Errorf("expected 6-digit code, got %s", code)
	}
}

