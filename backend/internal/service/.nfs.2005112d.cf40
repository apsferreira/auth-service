// ─── VerifyOTP ───────────────────────────────────────────────────────────────

func TestAuthService_VerifyOTP_Success(t *testing.T) {
	authSvc, mockUserRepo, mockTokenRepo, _, mockOTPRepo := createTestAuthService()

	userID := uuid.New()
	tenantID := uuid.New()
	hash, _ := bcrypt.GenerateFromPassword([]byte("123456"), bcrypt.DefaultCost)

	mockOTPRepo.FindLatestByEmailFn = func(email string) (*domain.OTPCode, error) {
		return &domain.OTPCode{
			ID:        uuid.New(),
			Email:     email,
			CodeHash:  string(hash),
			Attempts:  0,
			ExpiresAt: time.Now().Add(10 * time.Minute),
		}, nil
	}
	mockOTPRepo.IncrementAttemptsFn = func(id uuid.UUID) error {
		return nil
	}
	mockOTPRepo.DeleteByEmailFn = func(email string) error {
		return nil
	}
	mockUserRepo.FindByEmailFn = func(email string) (*domain.User, error) {
		return &domain.User{
			ID:       userID,
			TenantID: tenantID,
			Email:    email,
		}, nil
	}
	mockUserRepo.UpdateLastLoginFn = func(uid uuid.UUID) error {
		return nil
	}
	mockUserRepo.GetUserRolesAndPermissionsFn = func(uid uuid.UUID) ([]string, map[string][]string, error) {
		return []string{"user"}, map[string][]string{}, nil
	}
	mockTokenRepo.CreateFn = func(token *domain.RefreshToken) error {
		return nil
	}

	resp, err := authSvc.VerifyOTP("test@example.com", "123456")

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if resp == nil {
		t.Fatal("expected response, got nil")
	}
	if resp.AccessToken == "" {
		t.Error("expected access token")
	}
	if resp.RefreshToken == "" {
		t.Error("expected refresh token")
	}
}

