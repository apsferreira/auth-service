func TestAuthService_ProvisionUser_ExistingUser(t *testing.T) {
	authSvc, mockUserRepo, _, _, _ := createTestAuthService()

	existingUser := &domain.User{
		ID:    uuid.New(),
		Email: "test@example.com",
	}

	mockUserRepo.FindByEmailFn = func(email string) (*domain.User, error) {
		return existingUser, nil
	}

	user, err := authSvc.ProvisionUser("test@example.com", "Test User")

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if user.ID != existingUser.ID {
		t.Error("expected existing user to be returned")
	}
}

func TestAuthService_ProvisionUser_CreateNew(t *testing.T) {
	authSvc, mockUserRepo, _, _, _ := createTestAuthService()

	tenantID := uuid.New()
	roleID := uuid.New()

	mockUserRepo.FindByEmailFn = func(email string) (*domain.User, error) {
		return nil, sql.ErrNoRows
	}
	mockUserRepo.GetDefaultTenantIDFn = func() (uuid.UUID, error) {
		return tenantID, nil
	}
	mockUserRepo.GetDefaultRoleIDFn = func(tid uuid.UUID) (uuid.UUID, error) {
		return roleID, nil
	}
	mockUserRepo.CreateFn = func(user *domain.User) error {
		return nil
	}
	mockUserRepo.AddUserRoleFn = func(userID, roleID uuid.UUID) error {
		return nil
	}

	user, err := authSvc.ProvisionUser("test@example.com", "Test User")

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if user == nil {
		t.Fatal("expected user, got nil")
	}
	if user.Email != "test@example.com" {
		t.Errorf("expected email test@example.com, got %s", user.Email)
	}
}

