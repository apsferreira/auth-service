// ─── GetCurrentUser ──────────────────────────────────────────────────────────

func TestAuthService_GetCurrentUser_Success(t *testing.T) {
	authSvc, mockUserRepo, _, _, _ := createTestAuthService()

	userID := uuid.New()

	mockUserRepo.FindByIDFn = func(id uuid.UUID) (*domain.User, error) {
		return &domain.User{
			ID:    userID,
			Email: "test@example.com",
		}, nil
	}
	mockUserRepo.GetUserRolesAndPermissionsFn = func(uid uuid.UUID) ([]string, map[string][]string, error) {
		return []string{"admin"}, map[string][]string{}, nil
	}

	user, err := authSvc.GetCurrentUser(userID)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if user == nil {
		t.Fatal("expected user, got nil")
	}
	if len(user.Roles) != 1 || user.Roles[0].Name != "admin" {
		t.Error("expected role 'admin'")
	}
}

func TestAuthService_GetCurrentUser_NotFound(t *testing.T) {
	authSvc, mockUserRepo, _, _, _ := createTestAuthService()

	mockUserRepo.FindByIDFn = func(id uuid.UUID) (*domain.User, error) {
		return nil, sql.ErrNoRows
	}

	_, err := authSvc.GetCurrentUser(uuid.New())

	if err != sql.ErrNoRows {
		t.Fatalf("expected sql.ErrNoRows, got %v", err)
	}
}

// ─── AdminLogin ──────────────────────────────────────────────────────────────

func TestAuthService_AdminLogin_Success(t *testing.T) {
	authSvc, mockUserRepo, mockTokenRepo, _, _ := createTestAuthService()

	userID := uuid.New()
	tenantID := uuid.New()
	password := "admin123"
	hash, _ := bcrypt.GenerateFromPassword([]byte(password), bcrypt.DefaultCost)
	hashStr := string(hash)

	mockUserRepo.FindByUsernameOrEmailFn = func(identifier string) (*domain.User, error) {
		return &domain.User{
			ID:           userID,
			TenantID:     tenantID,
			Email:        "admin@example.com",
			PasswordHash: &hashStr,
		}, nil
	}
	mockUserRepo.GetUserRolesAndPermissionsFn = func(uid uuid.UUID) ([]string, map[string][]string, error) {
		return []string{"admin"}, map[string][]string{}, nil
	}
	mockUserRepo.UpdateLastLoginFn = func(uid uuid.UUID) error {
		return nil
	}
	mockTokenRepo.CreateFn = func(token *domain.RefreshToken) error {
		return nil
	}

	resp, err := authSvc.AdminLogin("admin@example.com", password)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if resp == nil {
		t.Fatal("expected response, got nil")
	}
	if resp.AccessToken == "" {
