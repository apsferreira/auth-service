// ─── ValidateToken ───────────────────────────────────────────────────────────

func TestAuthService_ValidateToken_Success(t *testing.T) {
	authSvc, _, _, _, _ := createTestAuthService()

	// Generate a valid token first
	userID := uuid.New()
	tenantID := uuid.New()
	jwtSvc := jwtpkg.NewJWTService("test-secret", 15*time.Minute, 7*24*time.Hour)
	
	accessToken, err := jwtSvc.GenerateAccessToken(userID, tenantID, "test@example.com", []string{"user"}, map[string][]string{})
	if err != nil {
		t.Fatalf("failed to generate token: %v", err)
	}

	// Create auth service with same secret
	authSvc.jwtService = jwtSvc

	resp, err := authSvc.ValidateToken(accessToken)

	if err != nil {
		t.Fatalf("expected no error, got %v", err)
	}
	if !resp.Valid {
		t.Error("expected token to be valid")
	}
	if resp.Email == nil || *resp.Email != "test@example.com" {
		t.Error("expected email in response")
	}
}

func TestAuthService_ValidateToken_Invalid(t *testing.T) {
	authSvc, _, _, _, _ := createTestAuthService()

	resp, err := authSvc.ValidateToken("invalid-token")

	if err != nil {
		t.Fatalf("expected no error (error in message), got %v", err)
	}
	if resp.Valid {
		t.Error("expected token to be invalid")
	}
}

