# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5433/auth_db?sslmode=disable

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Server
PORT=3002
ENV=development

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3003,http://localhost:5173

# Frontend
# VITE_API_URL= (leave empty in Docker, or http://localhost:3002 for local dev)

# Email (Resend - https://resend.com)
# Free tier: 100 emails/day
# In development mode (ENV=development), OTP is logged to stdout even without API key
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=auth@yourdomain.com

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_EMAIL=3
OTP_RATE_LIMIT_WINDOW_MINUTES=15

# WhatsApp (Evolution API - future)
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=your-evolution-api-key
# EVOLUTION_INSTANCE_NAME=auth-otp
